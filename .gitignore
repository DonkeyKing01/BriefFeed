# ── 密钥 & 个人环境 ──────────────────────────────────────────
.env

# ── 个人研究兴趣配置（含关键词/RSS）─────────────────────────
# 这些文件包含个人研究方向，不纳入版本库
# 请复制 *.template 文件并重命名后填写自己的内容
config/researcher_profile.md
config/settings.json
config/rss_sources.json

# ── 输出报告 ──────────────────────────────────────────────────
output/*
!output/.gitkeep

# ── n8n 本地数据（docker volume 挂载目录）────────────────────
.n8n/

# ── IDE / 编辑器配置 ──────────────────────────────────────────
.vscode/settings.json
.idea/
*.suo
*.user

# ── 系统文件 ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.log

# ── 临时文件 ──────────────────────────────────────────────────
*.tmp
*.bak
*.swp
