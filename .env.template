# BriefFeed 环境变量模板
# 使用方法：复制本文件为 .env，填入真实密钥后保存
#   cp .env.template .env
# 注意：.env 已被 .gitignore 忽略，不会上传到 Git

# ── 硅基流动 API 密钥（必须）────────────────────────────────
# 获取地址：https://cloud.siliconflow.cn/account/ak
SILICONFLOW_API_KEY=sk-your_siliconflow_api_key_here

# ── GitHub 个人访问令牌（可选，提升 API 速率限额）───────────
# 获取地址：https://github.com/settings/tokens
# 权限：只需勾选 public_repo（只读即可）
# 未配置时 GitHub 搜索仍可运行，但速率限制为 10 次/分钟
GITHUB_TOKEN=ghp_your_github_token_here
